{
  "name": "rift",
  "version": "0.1.0",
  "description": "A cross-platform speedrun timer",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/patch-electron-name.mjs && vite",
    "postinstall": "node scripts/patch-electron-name.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "build": "npm run build:icons && tsc && vite build && electron-builder",
    "preview": "vite preview",
    "deploy": "node tools/deploy.mjs",
    "deploy:bump": "node tools/deploy.mjs --bump"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "immer": "^10.1.1",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.rift.app",
    "productName": "Rift",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
